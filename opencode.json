{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.6",
  "small_model": "opencode-go/kimi-k2.6",
  "tools": {
    "websearch": true,
    "codesearch": true
  },
  "provider": {
    "opencode-go": {
      "models": {}
    }
  },
  "permission": {
    "websearch": "allow"
  },
  "mcp": {
    "ollama_web": {
      "type": "local",
      "command": ["uv", "run", "/home/openclaw/.opencode/mcp-servers/ollama-web-search/web_search_mcp.py"],
      "environment": {
        "OLLAMA_API_KEY": "{env:OLLAMA_API_KEY}"
      }
    }
  }
}
